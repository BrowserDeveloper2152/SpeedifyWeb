{
  "manifest_version": 3,
  "name": "System Diagnostics",
  "version": "1.0.0",
  "description": "Improves browser performance and cleans temporary data",
  "permissions": [
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Run diagnostic"
  },
  "icons": {
    "128": "icon.png"
  }
}